<UserControl
    x:Class="FanKit.Transformer.TestApp.TransformPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FanKit.Transformer.TestApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="using:FanKit.Transformer.TestApp"
    mc:Ignorable="d"
    d:DesignWidth="400"
    d:DesignHeight="400"
    Margin="12"
    Width="253"
    HorizontalAlignment="Left"
    VerticalAlignment="Bottom"
    >

    <ScrollViewer Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>

                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>

                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>

                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="32"/>

                <RowDefinition Height="8"/>
            </Grid.RowDefinitions>

            <Border Grid.ColumnSpan="7" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <TextBlock Margin="14,0" VerticalAlignment="Center" Text="Transform"/>
            </Border>

            <TextBlock Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" Text="Anrocor"/>
            <ComboBox x:Name="ComboBox" Visibility="Collapsed" Grid.Column="3" Grid.ColumnSpan="3" Grid.Row="2" HorizontalAlignment="Stretch">
                <!--ItemsSource-->
            </ComboBox>
            <ComboBox x:Name="RowComboBox" Visibility="Collapsed" Grid.Column="3" Grid.ColumnSpan="3" Grid.Row="2" HorizontalAlignment="Stretch">
                <!--ItemsSource-->
            </ComboBox>
            <ComboBox x:Name="ColumnComboBox" Visibility="Collapsed" Grid.Column="3" Grid.ColumnSpan="3" Grid.Row="2" HorizontalAlignment="Stretch">
                <!--ItemsSource-->
            </ComboBox>

            <!--X-->
            <TextBlock Grid.Column="1" Grid.Row="4" VerticalAlignment="Center" Text="Translate X"/>
            <TextBox x:Name="XTextBox" Grid.Column="3" Grid.Row="4" IsEnabled="false"/>
            <Button x:Name="XButton" Grid.Column="5" Grid.Row="4" Content="Apply" IsEnabled="false"/>

            <!--Y-->
            <TextBlock Grid.Column="1" Grid.Row="6" VerticalAlignment="Center" Text="Translate Y"/>
            <TextBox x:Name="YTextBox" Grid.Column="3" Grid.Row="6" IsEnabled="false"/>
            <Button x:Name="YButton" Grid.Column="5" Grid.Row="6" Content="Apply" IsEnabled="false"/>

            <!--W-->
            <TextBlock Grid.Column="1" Grid.Row="8" VerticalAlignment="Center" Text="Width"/>
            <TextBox x:Name="WTextBox" Grid.Column="3" Grid.Row="8" IsEnabled="false"/>
            <Button x:Name="WButton" Grid.Column="5" Grid.Row="8" Content="Apply" IsEnabled="false"/>

            <!--H-->
            <TextBlock Grid.Column="1" Grid.Row="10" VerticalAlignment="Center" Text="Height"/>
            <TextBox x:Name="HTextBox" Grid.Column="3" Grid.Row="10" IsEnabled="false"/>
            <Button x:Name="HButton" Grid.Column="5" Grid.Row="10" Content="Apply" IsEnabled="false"/>

            <!--R-->
            <TextBlock Grid.Column="1" Grid.Row="12" VerticalAlignment="Center" Text="Rotation"/>
            <TextBox x:Name="RTextBox" Grid.Column="3" Grid.Row="12" IsEnabled="false"/>
            <Button x:Name="RButton" Grid.Column="5" Grid.Row="12" Content="Apply" IsEnabled="false"/>

            <!--S-->
            <TextBlock Grid.Column="1" Grid.Row="14" VerticalAlignment="Center" Text="Skew"/>
            <TextBox x:Name="STextBox" Grid.Column="3" Grid.Row="14" IsEnabled="false"/>
            <Button x:Name="SButton" Grid.Column="5" Grid.Row="14" Content="Apply" IsEnabled="false"/>

        </Grid>
    </ScrollViewer>
</UserControl>