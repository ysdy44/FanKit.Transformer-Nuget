<UserControl
    x:Class="FanKit.Transformer.TestApp.NodeMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FanKit.Transformer.TestApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="200"
    d:DesignHeight="400"
    >

    <StackPanel>
        <TextBlock Margin="0,4" Text="Fixed"/>
        <RadioButton x:Name="NoneButton" GroupName="Fixed" IsChecked="True" Content="None"/>
        <RadioButton x:Name="AngleButton" GroupName="Fixed" Content="Fixed Angle"/>
        <RadioButton x:Name="LengthButton" GroupName="Fixed" Content="Fixed Length"/>

        <!--Top=89.6-18=61.6-->
        <!--Bottom=61.6-12=59.6-->
        <TextBlock Margin="0,4" Text="Mode"/>
        <RadioButton x:Name="MirroredButton" GroupName="Node" IsChecked="True">
            <Canvas Width="76.8" Height="59.6">
                <Path Data="M13.1966,55.8011c0,0 0.7333,-5.2381 1.6056,-7.7162c1.6801,-4.7725 9.5528,-18.9054 24.2638,-18.7777c16.0509,0.1394 22.9257,14.0201 24.3976,18.1533c0.9159,2.5719 1.8287,7.9838 1.8287,7.9838" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}" Fill="#3A9AFD"/>

                <Line X1="18.6502" Y1="28.2" X2="63" Y2="28.2" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Ellipse Canvas.Left="57.6" Canvas.Top="24.6" Width="7" Height="7" Fill="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Ellipse Canvas.Left="13.8" Canvas.Top="24.9" Width="7" Height="7" Fill="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>

                <Ellipse Canvas.Left="31.9" Canvas.Top="20.9" Width="13" Height="13" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}" Fill="{ThemeResource SystemControlBackgroundAltHighBrush}"/>

                <TextBlock FontSize="14" Text="Mirrored"/>
            </Canvas>
        </RadioButton>
        <RadioButton x:Name="DisconnectedButton" GroupName="Node">
            <Canvas Width="76.8" Height="59.6">
                <Path Data="M13.1966,55.8011c0,0 0.7333,-5.2381 1.6056,-7.7162c1.6801,-4.7725 11.7931,-26.5823 24.2638,-18.7777c12.873,8.0563 26.2263,26.1371 26.2263,26.1371" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}" Fill="#3A9AFD"/>

                <Line X1="36" Y1="26" X2="19" Y2="28.2" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Line X1="36" Y1="26" X2="55.5" Y2="44" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Ellipse Canvas.Left="50" Canvas.Top="38" Width="7" Height="7" Fill="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Ellipse Canvas.Left="13.8" Canvas.Top="24.9" Width="7" Height="7" Fill="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>

                <Ellipse Canvas.Left="28" Canvas.Top="20.9" Width="13" Height="13" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}" Fill="{ThemeResource SystemControlBackgroundAltHighBrush}"/>

                <TextBlock FontSize="14" Text="Disconnected"/>
            </Canvas>
        </RadioButton>
        <RadioButton x:Name="AsymmetricButton" GroupName="Node">
            <Canvas Width="76.8" Height="59.6">
                <Path Data="M13.1966,55.8011c0,0 0.8048,-8.6536 1.5499,-11.1729c1.3455,-4.5495 3.4756,-16.062 18.1867,-15.9343c16.0508,0.1394 26.2709,8.166 30.5304,18.7666c1.018,2.5333 1.8287,7.9838 1.8287,7.9838" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}" Fill="#3A9AFD"/>

                <Line X1="18.6502" Y1="28.2" X2="63" Y2="28.2" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Ellipse Canvas.Left="57.6" Canvas.Top="24.6" Width="7" Height="7" Fill="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>
                <Ellipse Canvas.Left="13.8" Canvas.Top="24.9" Width="7" Height="7" Fill="{ThemeResource SystemControlBackgroundBaseHighBrush}"/>

                <Ellipse Canvas.Left="27" Canvas.Top="20.9" Width="13" Height="13" StrokeThickness="3" Stroke="{ThemeResource SystemControlBackgroundBaseHighBrush}" Fill="{ThemeResource SystemControlBackgroundAltHighBrush}"/>

                <TextBlock FontSize="14" Text="Asymmetric"/>
            </Canvas>
        </RadioButton>

    </StackPanel>
</UserControl>