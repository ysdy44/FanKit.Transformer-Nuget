<Canvas
    x:Class="FanKit.Transformer.TestApp.TouchPad"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FanKit.Transformer.TestApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="400"
    d:DesignHeight="400"
    >

    <Line x:Name="Line" StrokeThickness="2" Stroke="Gray"/>
    <Thumb x:Name="Thumb2" Width="36" Height="36">
        <Thumb.Template>
            <ControlTemplate>
                <Ellipse Width="36" Height="36" StrokeThickness="4" Stroke="LightSeaGreen" Fill="White"/>
            </ControlTemplate>
        </Thumb.Template>
    </Thumb>
    <Thumb x:Name="Thumb1" Width="36" Height="36" >
        <Thumb.Template>
            <ControlTemplate>
                <Ellipse Width="36" Height="36" StrokeThickness="4" Stroke="Gray" Fill="White"/>
            </ControlTemplate>
        </Thumb.Template>
    </Thumb>
    <Thumb x:Name="ThumbCenter" Width="24" Height="24">
        <Thumb.Template>
            <ControlTemplate>
                <Ellipse Width="24" Height="24" StrokeThickness="6" Stroke="Gray" Fill="White"/>
            </ControlTemplate>
        </Thumb.Template>
    </Thumb>

</Canvas>